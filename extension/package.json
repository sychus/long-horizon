{
  "name": "long-horizon",
  "displayName": "Long Horizon",
  "description": "Live observability for MemPalace MCP retrieval — token costs, latency, and spatial traversal",
  "version": "0.1.0",
  "publisher": "gentleman",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "long-horizon.setup",
        "title": "Long Horizon: Setup"
      },
      {
        "command": "long-horizon.showMap",
        "title": "Long Horizon: Show Palace Map"
      },
      {
        "command": "long-horizon.showTimeline",
        "title": "Long Horizon: Show Event Timeline"
      },
      {
        "command": "long-horizon.clearSession",
        "title": "Long Horizon: Clear Session"
      },
      {
        "command": "long-horizon.exportSession",
        "title": "Long Horizon: Export Session"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "long-horizon",
          "title": "Long Horizon",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "long-horizon": [
        {
          "id": "long-horizon.timeline",
          "name": "Event Timeline"
        }
      ]
    },
    "configuration": {
      "title": "Long Horizon",
      "properties": {
        "long-horizon.wsPort": {
          "type": "number",
          "default": 19420,
          "description": "WebSocket port to connect to the long-horizon proxy"
        },
        "long-horizon.tokenWarningThreshold": {
          "type": "number",
          "default": 2000,
          "description": "Token count above which a warning icon appears"
        },
        "long-horizon.latencyWarningMs": {
          "type": "number",
          "default": 500,
          "description": "Latency above which the row turns red"
        },
        "long-horizon.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Auto-open the palace map when a session starts"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outdir=dist --platform=node --format=cjs --external:vscode --sourcemap && esbuild src/webview/mapView.ts --bundle --outdir=dist --platform=browser --format=iife --sourcemap",
    "watch": "pnpm build --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/d3-color": "^3.1.3",
    "@types/d3-force": "^3.0.10",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.18.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "d3-color": "^3.1.0",
    "d3-dispatch": "^3.0.1",
    "d3-ease": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-timer": "^3.0.1",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "ws": "^8.21.0"
  }
}
